# Trading App - Environment Configuration Template
# IMPORTANT: This file contains PLACEHOLDERS ONLY
# Copy this to .env and replace ALL values with your actual credentials
# Never commit .env to git - it will be auto-excluded by .gitignore

# ============================================================================
# DATABASE
# ============================================================================
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://postgres:MySecurePassword123@db.example.com:5432/trading_app
DATABASE_URL=<ENTER_YOUR_DATABASE_URL>

# ============================================================================
# DHANQ REST API CREDENTIALS
# ============================================================================
# Get these from: https://dhanhq.co/
DHAN_CLIENT_ID=<ENTER_YOUR_DHAN_CLIENT_ID>
DHAN_ACCESS_TOKEN=<ENTER_YOUR_DHAN_ACCESS_TOKEN>

# For Static IP Mode (recommended for production):
DHAN_API_KEY=<ENTER_YOUR_DHAN_API_KEY>
DHAN_API_SECRET=<ENTER_YOUR_DHAN_API_SECRET>

# For TOTP Auto-Refresh (if using 24/7 operation):
DHAN_PIN=<ENTER_YOUR_6_DIGIT_PIN>
DHAN_TOTP_SECRET=<ENTER_YOUR_TOTP_SECRET>

# ============================================================================
# SMS/OTP PROVIDER
# ============================================================================
# Get these from your SMS gateway provider
MESSAGE_CENTRAL_CUSTOMER_ID=<ENTER_YOUR_SMS_CUSTOMER_ID>
MESSAGE_CENTRAL_PASSWORD=<ENTER_YOUR_SMS_PASSWORD>

OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ============================================================================
# EMAIL OTP SERVICE
# ============================================================================
# Configure your email/OTP service endpoint
EMAIL_OTP_SERVICE_BASE_URL=<ENTER_YOUR_OTP_SERVICE_URL>
EMAIL_OTP_SERVICE_TIMEOUT_SECONDS=15
EMAIL_OTP_EXPIRY_SECONDS=300

# ============================================================================
# APP CONFIGURATION
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS_RAW=*

# ============================================================================
# STARTUP FLAGS
# ============================================================================
DISABLE_DHAN_WS=false
STARTUP_START_STREAMS=true
STARTUP_LOAD_MASTER=true
STARTUP_LOAD_TIER_B=true

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
SECURITY_BURST_WINDOW_SECONDS=300
SECURITY_BURST_ACTIONS_THRESHOLD=60
SECURITY_IMPOSSIBLE_TRAVEL_WINDOW_MINUTES=120
SECURITY_IMPOSSIBLE_TRAVEL_SPEED_KMH=900.0
